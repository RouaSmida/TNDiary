# API server env – copy to .env and fill in your values
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://tndiary:tndiary_secret@localhost:5432/tndiary

# Session
SESSION_SECRET=change_this_to_a_long_random_string

